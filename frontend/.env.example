# ----------------------------------------------------------------------------
# JobHub Frontend — environment template
# ----------------------------------------------------------------------------
# Copy this file to ".env" and adjust. Only VITE_* variables are exposed to
# the client bundle. NEVER put secrets here — anything prefixed with VITE_
# is readable by anyone in the browser.
# ----------------------------------------------------------------------------

# Base URL of the JobHub backend API.
# In development the Vite dev server proxies "/api" to this target (see vite.config.js).
VITE_API_BASE_URL=/api
