# ============================================================
# Backend environment variables
# ============================================================
# Copy this file to `.env` and fill in real values.
# NEVER commit `.env` (already in .gitignore).
# ------------------------------------------------------------

# Server
NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:5173

# JWT — Generate a strong random secret (>= 64 chars) before running the server.
# The server will REFUSE to start if this is missing or uses the placeholder value.
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REPLACE_WITH_MINIMUM_64_CHAR_RANDOM_SECRET
JWT_ACCESS_TOKEN_TTL=15m
JWT_REFRESH_TOKEN_TTL=7d

# Supabase — get from Supabase Dashboard → Project Settings → API
# service_role key is SECRET — never expose it to the frontend.
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY_HERE
SUPABASE_ANON_KEY=YOUR_ANON_KEY_HERE

# DeepSeek AI
DEEPSEEK_API_KEY=YOUR_DEEPSEEK_API_KEY_HERE
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# Logging
LOG_LEVEL=debug
