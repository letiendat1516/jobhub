# ============================================================
# Backend environment variables
# ============================================================
# Copy file này thành `.env` và điền giá trị thật.
# KHÔNG commit `.env` (đã có trong .gitignore).
# ------------------------------------------------------------

# Server
NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:5173

# JWT — ĐẶT SECRET MẠNH trong production (chuỗi random >= 64 ký tự).
# Tạo nhanh:  node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change-me-to-a-long-random-secret
JWT_ACCESS_TOKEN_TTL=15m
JWT_REFRESH_TOKEN_TTL=7d

# Supabase — lấy từ Supabase Dashboard → Project Settings → API
# (service_role key là BÍ MẬT, không bao giờ để lộ ra frontend)
SUPABASE_URL=https://cnhyvmqddbxgmausuyxq.supabase.co
SUPABASE_SERVICE_ROLE_KEY=PASTE_YOUR_SERVICE_ROLE_KEY_HERE
SUPABASE_ANON_KEY=sb_publishable_ELjoFTJrp2S0zMSeX1NVAg_F6eQSGCm

# DeepSeek AI
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# Logging
LOG_LEVEL=debug
